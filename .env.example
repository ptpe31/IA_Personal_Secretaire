# Clé API Google Gemini pour l'analyse documentaire (prioritaire sur Ollama)
GEMINI_API_KEY=

# Modèle Gemini (fixe : gemini-2.5-flash — SDK google.genai)
# GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (mode Éco — optionnel, configurable aussi dans Paramètres)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=qwen/qwen-2.5-vl-72b-instruct

# Relance email Gmail (mot de passe d'application Google — jamais le mot de passe du compte)
# SMTP_SENDER_EMAIL=ton_email@gmail.com
# SMTP_RECIPIENT_EMAIL=ton_email@gmail.com
# SMTP_APP_PASSWORD=
